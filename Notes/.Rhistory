library(mvtnorm)
library(truncnorm)
library(coda)
run_full_gibbs <- function(clouds, n_iter = 30000, burn_in = 5000) {
z <- clouds$z
delta <- clouds$delta
n <- length(z)
# Initialize y: if observed, y=z; if censored, initialize above the limit
y <- z
y[delta == 0] <- z[delta == 0] + 0.5
# Storage for parameters
samples <- matrix(NA, nrow = n_iter, ncol = 3)
colnames(samples) <- c("beta0", "beta1", "tau")
# Initial parameter values
curr_beta <- c(mean(y)*(1-0.9), 0.9) # Rough start
curr_tau <- 1/var(y)
for (i in 1:n_iter) {
# --- STEP 1: Update beta, tau (Independence Sampler) ---
X <- cbind(1, y[1:(n-1)])
Q <- t(X) %*% X
beta_hat <- solve(Q) %*% t(X) %*% y[2:n]
ssr <- sum((y[2:n] - X %*% beta_hat)^2)
# Draw proposal from point d
tau_prop <- rgamma(1, shape = (n - 2) / 2, rate = ssr / 2)
beta_prop <- as.vector(rmvnorm(1, mean = beta_hat, sigma = solve(tau_prop * Q)))
# MH step using correction from point c
log_H <- function(b, t, y1) {
if(abs(b[2]) >= 1) return(-Inf)
0.5*log(1-b[2]^2) - log(1-b[2]) - (t/2)*(1-b[2]^2)*(y1 - b[1]/(1-b[2]))^2
}
alpha <- exp(log_H(beta_prop, tau_prop, y[1]) - log_H(curr_beta, curr_tau, y[1]))
if (runif(1) < alpha) {
curr_beta <- beta_prop
curr_tau <- tau_prop
}
samples[i, ] <- c(curr_beta, curr_tau)
# --- STEP 2: Update latent y_j (Truncated Normal from point f) ---
mu <- curr_beta[1] / (1 - curr_beta[2])
phi <- curr_beta[2]
prec_y <- curr_tau * (1 + phi^2)
# Update interior censored points (j=2 to n-1)
cens_idx <- which(delta == 0)
# Interior indices only for the triplet formula
interior_cens <- cens_idx[cens_idx > 1 & cens_idx < n]
for (j in interior_cens) {
cond_mean <- mu + (phi / (1 + phi^2)) * (y[j-1] + y[j+1] - 2*mu)
y[j] <- rtruncnorm(1, a = z[j], b = Inf, mean = cond_mean, sd = 1/sqrt(prec_y))
}
# (Note: Boundary points y[1] and y[n] would use AR(1) forward/backward steps)
}
# Convert to mcmc object
return(mcmc(samples[(burn_in + 1):n_iter, ]))
}
# Run and analyze
res <- run_full_gibbs(clouds)
summary(res)
plot(res)
summary(res)
plot(res)
autocorr.plot(res)
effectiveSize(res)
library(mvtnorm)
mh_sampler <- function(y, n_iter = 10000, burn_in = 1000) {
n <- length(y)
p <- 2
# 1. Prepare data for the proposal (*)
y_curr <- y[2:n]
X <- cbind(1, y[1:(n-1)])
Q <- t(X) %*% X
Q_inv <- solve(Q)
beta_hat <- Q_inv %*% t(X) %*% y_curr
ssr <- sum((y_curr - X %*% beta_hat)^2)
# 2. Storage
samples <- matrix(NA, nrow = n_iter, ncol = 3)
colnames(samples) <- c("beta0", "beta1", "tau")
acc_count <- 0
# 3. Log-second function helper
log_second <- function(b0, b1, tau, y1) {
if (abs(b1) >= 1) return(-Inf) # Stationary constraint
val <- 0.5 * log(1 - b1^2) - log(1 - b1) -
(tau / 2) * (1 - b1^2) * (y1 - b0 / (1 - b1))^2
return(val)
}
# Initial state
samples[1, ] <- c(beta_hat, 1)
# 4. Metropolis-Hastings Loop
for (i in 2:n_iter) {
# Step d: Compositional Sampling from Proposal Q
tau_prop <- rgamma(1, shape = (n - p) / 2, rate = ssr / 2)
beta_prop <- rmvnorm(1, mean = beta_hat, sigma = solve(tau_prop * Q))
b0_p <- beta_prop[1]; b1_p <- beta_prop[2]
b0_c <- samples[i-1, 1]; b1_c <- samples[i-1, 2]; tau_c <- samples[i-1, 3]
# Step c: Compute Log-Acceptance Ratio
log_alpha <- log_second(b0_p, b1_p, tau_prop, y[1]) -
log_second(b0_c, b1_c, tau_c, y[1])
if (log(runif(1)) < log_alpha) {
samples[i, ] <- c(b0_p, b1_p, tau_prop)
acc_count <- acc_count + 1
} else {
samples[i, ] <- samples[i-1, ]
}
}
cat("Overall Acceptance Rate:", acc_count / (n_iter - 1), "\n")
return(samples[(burn_in + 1):n_iter, ])
}
