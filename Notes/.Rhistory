run_gibbs_sampler <- function(clouds, n_iter = 20000, burn_in = 5000) {
z <- clouds$z
delta <- clouds$delta
n <- length(z)
# Initialize y: observed z, and for censored, use z + small noise
y <- z
y[delta == 0] <- z[delta == 0] + 0.1
# Storage
res_params <- matrix(NA, n_iter, 3)
colnames(res_params) <- c("beta0", "beta1", "tau")
# Initialize parameters
curr_beta <- c(0.5, 0.5)
curr_tau <- 1
for (i in 1:n_iter) {
# --- STEP 1: Update beta, tau (MH Independence Sampler from point e) ---
# We run one MH step using the 'current' y as if it were the truth
X <- cbind(1, y[1:(n-1)])
Q <- t(X) %*% X
beta_hat <- solve(Q) %*% t(X) %*% y[2:n]
ssr <- sum((y[2:n] - X %*% beta_hat)^2)
# Propose
tau_prop <- rgamma(1, (n-2)/2, ssr/2)
beta_prop <- as.vector(rmvnorm(1, beta_hat, solve(tau_prop * Q)))
# Acceptance probability (only first obs correction as derived in point c)
log_H <- function(b, t, y1) {
if(abs(b[2]) >= 1) return(-Inf)
0.5*log(1-b[2]^2) - log(1-b[2]) - (t/2)*(1-b[2]^2)*(y1 - b[1]/(1-b[2]))^2
}
log_alpha <- log_H(beta_prop, tau_prop, y[1]) - log_H(curr_beta, curr_tau, y[1])
if (log(runif(1)) < log_alpha) {
curr_beta <- beta_prop
curr_tau <- tau_prop
}
# --- STEP 2: Update latent y_j (Gibbs steps from point f) ---
mu <- curr_beta[1] / (1 - curr_beta[2])
phi <- curr_beta[2]
cond_sd <- sqrt(1 / (curr_tau * (1 + phi^2)))
# Update only censored interior points (j=2 to n-1)
cens_idx <- which(delta == 0)
cens_idx <- cens_idx[cens_idx > 1 & cens_idx < n]
for (j in cens_idx) {
cond_mean <- mu + (phi / (1 + phi^2)) * (y[j-1] + y[j+1] - 2*mu)
y[j] <- rtruncnorm(1, a = z[j], b = Inf, mean = cond_mean, sd = cond_sd)
}
# (Note: y[1] and y[n] can be handled with simpler AR(1) conditionals)
res_params[i, ] <- c(curr_beta, curr_tau)
}
return(res_params[(burn_in+1):n_iter, ])
}
run_gibbs_sampler(clouds)
