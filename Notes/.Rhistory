# PLOTS
# ------------------------------------------------------------
par(mfrow = c(1,2))
image(x, y, Zmat_prior,
col = plasma(200),
useRaster = TRUE,
main = expression("Prior GRF (" ~ nu == 1.9 ~ ")"))
points(obs_locations, pch = 19, col = "red")
image(x, y, Zmat_post,
col = plasma(200),
useRaster = TRUE,
main = expression("Posterior GRF (" ~ sigma[e]^2 == 0.25 ~ ")"))
points(obs_locations, pch = 19, col = "red")
library(viridis)
rm(list = ls())
# ------------------------------------------------------------
# PARAMETERS
# ------------------------------------------------------------
scale <- 10
nx <- 30
ny <- 30
xi  <- 1
nu  <- 1.9
var_r <- 5
sigma_e2 <- 0.25
# ------------------------------------------------------------
# GRID
# ------------------------------------------------------------
x <- seq(0, 50, length.out = nx) / scale
y <- seq(0, 50, length.out = ny) / scale
grid <- expand.grid(x = x, y = y)
n_total <- nrow(grid)
# ------------------------------------------------------------
# COVARIANCE FUNCTION
# ------------------------------------------------------------
cov_matrix_2d <- function(grid, xi, nu, var){
n <- nrow(grid)
Sigma <- matrix(0, n, n)
for(i in 1:n){
for(j in 1:n){
dx <- grid$x[i] - grid$x[j]
dy <- grid$y[i] - grid$y[j]
dist <- sqrt(dx^2 + dy^2)
Sigma[i,j] <- var * exp(-xi * dist^nu)
}
}
Sigma
}
Sigma <- cov_matrix_2d(grid, xi, nu, var_r)
# ------------------------------------------------------------
# MULTIVARIATE NORMAL SAMPLER (CHOL)
# ------------------------------------------------------------
mvnchol <- function(mu, S){
L <- t(chol(S))
z <- rnorm(length(mu))
as.vector(mu + L %*% z)
}
# ------------------------------------------------------------
# PRIOR REALISATION
# ------------------------------------------------------------
z_prior <- mvnchol(rep(0, n_total), Sigma)
Zmat_prior <- matrix(z_prior, nx, ny)
# ------------------------------------------------------------
# CHOOSE EXACT OBSERVATION LOCATIONS (x,y)
# ------------------------------------------------------------
# YOU CAN CHANGE THESE FREELY
obs_locations <- matrix(c(
1.5, 1.0,
3.0, 4.0,
4.5, 2.5
), ncol = 2, byrow = TRUE)
n_obs <- nrow(obs_locations)
# Find nearest grid indices
obs_index <- apply(obs_locations, 1, function(pt){
which.min( (grid$x - pt[1])^2 + (grid$y - pt[2])^2 )
})
# Observed values taken from PRIOR realisation
d_obs <- c(15, -10, -5)
# ------------------------------------------------------------
# BUILD OBSERVATION MATRIX H
# ------------------------------------------------------------
H <- matrix(0, n_obs, n_total)
for(i in 1:n_obs){
H[i, obs_index[i]] <- 1
}
# ------------------------------------------------------------
# POSTERIOR (FULL FIELD)
# ------------------------------------------------------------
# Posterior mean
mu_post <- Sigma %*% t(H) %*%
solve(H %*% Sigma %*% t(H) + sigma_e2 * diag(n_obs)) %*%
d_obs
# Posterior covariance
Sigma_post <- Sigma -
Sigma %*% t(H) %*%
solve(H %*% Sigma %*% t(H) + sigma_e2 * diag(n_obs)) %*%
H %*% Sigma
# Posterior realisation
z_post <- mvnchol(mu_post, Sigma_post)
Zmat_post <- matrix(z_post, nx, ny)
# ------------------------------------------------------------
# PLOTS
# ------------------------------------------------------------
par(mfrow = c(1,2))
image(x, y, Zmat_prior,
col = plasma(200),
useRaster = TRUE,
main = expression("Prior GRF (" ~ nu == 1.9 ~ ")"))
points(obs_locations, pch = 19, col = "red")
image(x, y, Zmat_post,
col = plasma(200),
useRaster = TRUE,
main = expression("Posterior GRF (" ~ sigma[e]^2 == 0.25 ~ ")"))
points(obs_locations, pch = 19, col = "red")
