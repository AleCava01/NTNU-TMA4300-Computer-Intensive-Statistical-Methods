beta0    beta1      tau 
7491.182 7676.655 8632.981 
\end{lstlisting}

Ignoring censoring, $(*)$ is a very good proposal: the high observed acceptance rate of 92.8\% is a direct consequence of the efficiency of our Metropolis-Hastings sampler. As derived in Equation \ref{p3pb_likelihood}, $Q(\pmb \beta, \tau | \pmb y)$ corresponds to the likelihood of the transition steps from $t=2$ to $n$. 
Consequently, the proposal is nearly identical to the full target posterior $\pi(\pmb \beta, \tau | \pmb y)$, differing only by the marginal likelihood contribution of the first observation $y_1$ and the prior structure.

This theoretical efficiency is empirically confirmed by the rapid convergence of the chain. Trace and density plots \ref{fig:trace_density_ignoring_censoring} show a "fuzzy caterpillar" appearance and unimodal, symmetric distributions, indicating that the sampler has successfully reached the stationary distribution. Furthermore, the autocorrelation decays fastly toward zero, falling within the 95\% confidence intervals and the $\pm 0.1$ threshold within fewer than 40 lags. 
The reliability of the posterior inference is ultimately justified by the high Effective Sample Sizes (ESS), exceeding 7,400 for all parameters.



\subsection{Point f)}
For a first order autoregressive process $y_t-\mu = \phi (y_{t-1}-\mu) +\varepsilon_t$, the joint distribution of any three consecutive observations can be expressed via its precision matrix Q:
$$
    \begin{bmatrix}
        y_{j-1}\\ y_j \\ y_{j+1}
    \end{bmatrix}
    \sim\mathcal N \begin{pmatrix}\mu \pmb 1, \tau^{{-1}} \begin{bmatrix}
        1 & -\phi & 0\\
        -\phi & 1+\phi^2 & -\phi \\ 
        0 & -\phi &  1
    \end{bmatrix}^{-1}\end{pmatrix}
$$

For a multivariate Normal vector $\pmb y \sim \mathcal N (\pmb \mu, \pmb Q^{-1})$, the conditional distribution of a single component $y_j$ given all other components $\pmb y_{-j}$ is also Normal:
$$
    y_j |\pmb y_{-j} \sim \mathcal N \begin{pmatrix}
        \mu_j -\frac{1}{Q_{jj}} \sum_{k\neq j} Q_{jk} (y_k-\mu_k ), \frac 1{Q_{jj}}
    \end{pmatrix}
$$

We now extract the relevant term from the precision matrix $\pmb Q$ to find the conditional parameters for $y_j$.

The diagonal element corresponding to $y_j$ is $Q_{jj} = \tau (1+\phi^2)$. Therefore, the conditional variance is the inverse of this precision:
$$
    \text{Var} (y_j| \pmb y_{-j} ) = \frac 1{\tau (1+\phi^2)} = \frac{\tau^{-1}}{1+\phi^2}
$$

The non-zero off-diagonal elements in the $j$-th row of $\pmb Q$ are $Q_{j,j-1} = -\tau \phi$ and $Q_{j,j+1}=-\tau \phi$.
Plugging these into the formula for the conditional mean:
\begin{align*}
    \mathbb E[y_j | \pmb y_{-j}] & = \mu - \frac{1}{\tau (1+\phi ^2)}\Big [Q_{j,j-1}(y_{j-1}-\mu)+ Q_{j,j+1}(y_{j+1}-\mu)\Big ] = \\ &=  \mu - \frac{1}{\tau (1+\phi ^2)}\Big [ -\tau \phi (y_{j-1}-\mu) -\tau \phi (y_{j+1}-\mu)\Big ] = \\
    & =  \mu + \frac{\tau \phi }{\tau (1+\phi ^2)}\Big [(y_{j-1}-\mu) + (y_{j+1}-\mu)\Big ] = \\
    & =  \mu + \frac{\phi }{1+\phi ^2}(y_{j-1}+y_{j+1}-2\mu)
\end{align*}

Eventually combining the results, we obtain the required conditional distribution:
$$
    y_j | \pmb y_{-j}, \pmb \beta, \tau \sim \mathcal N\begin{pmatrix}
        \mu+\frac{\phi}{1+\phi^2}(y_{j-1}+y_{j+1} -2\mu), \frac{\tau^{-1}}{1+\phi^2}
    \end{pmatrix}
$$


\subsubsection{Density of $y_j$ conditioned on the data}

The density of $y_j$ conditioned on $\pmb y_{−j},\pmb \delta,\pmb z,\pmb \beta,\tau$ is a truncated normal distribution if the observation is censored and a point mass if it is observed.

Letting $\mu_{cond} = \mu + \frac{\phi}{1+\phi^2}(y_{j-1} + y_{j+1} - 2\mu)$ and $\sigma^2_{cond} = \frac{1}{\tau(1+\phi^2)}$, 

\begin{itemize}
    \item If $\delta_j = 1$ (Observed): The true value is known, and thus the density is a Dirac delta function centered at $z_j$:
    $$
        p(y_j \mid \pmb y_{-j}, \pmb \delta, \pmb z, \pmb \beta, \tau) = \delta(y_j - z_j)
    $$
    
    \item If $\delta_j = 0$ (Right-Censored), then $y_t > z_t$. Therefore, the density is the AR(1) conditional Normal density from Point f, truncated to the interval $(z_j, \infty)$:
    $$
        p(y_j \mid \pmb y_{-j}, \delta_j=0, z_j, \pmb \beta, \tau) = \frac{\mathcal{N}(y_j \mid \mu_{cond}, \sigma^2_{cond})}{\int_{z_j}^{\infty} \mathcal{N}(u \mid \mu_{cond}, \sigma^2_{cond}) du} \cdot \mathbb{I}(y_j > z_j)
    $$
\end{itemize}

\subsection{Point g)}

\begin{rcodebox}
    
<<point_g, echo=TRUE, eval=FALSE, fig.pos="H", out.width="60%", fig.align="center", fig.height=5, fig.width=6, fig.cap="">>=

library(mvtnorm)
library(truncnorm)
library(coda)

gibbs_censored_ar1 <- function(clouds, n_iter = 20000) {
  z <- clouds$z
  delta <- clouds$delta
  n <- length(z)
  p <- 2
  
  y_curr <- z
  y_curr[delta == 0] <- z[delta == 0] + 0.5
  
  samples <- matrix(NA, nrow = n_iter, ncol = 3)
  colnames(samples) <- c("beta0", "beta1", "tau")
  
  curr_params <- c(0.1, 0.5, 1)
  acc_count <- 0
  
  log_H <- function(b0, b1, tau, y1) {
    if (abs(b1) >= 1) return(-Inf)
    0.5 * log(1 - b1^2) - log(1 - b1) - 
    (tau / 2) * (1 - b1^2) * (y1 - b0 / (1 - b1))^2
  }
  
  for (i in 1:n_iter) {
    
    y_reg <- y_curr[2:n]
    X <- cbind(1, y_curr[1:(n-1)])
    Q <- t(X) %*% X
    beta_hat <- solve(Q) %*% t(X) %*% y_reg
    ssr <- sum((y_reg - X %*% beta_hat)^2)
    
    tau_prop <- rgamma(1, shape = (n - p) / 2, rate = ssr / 2)
    beta_prop <- as.vector(rmvnorm(1, mean = beta_hat, sigma = solve(tau_prop * Q)))
    
    log_alpha <- log_H(beta_prop[1], beta_prop[2], tau_prop, y_curr[1]) - 
                 log_H(curr_params[1], curr_params[2], curr_params[3], y_curr[1])
    
    if (log(runif(1)) < log_alpha) {
      curr_params <- c(beta_prop, tau_prop)
      acc_count <- acc_count + 1
    }
    samples[i, ] <- curr_params
    
    mu <- curr_params[1] / (1 - curr_params[2])
    phi <- curr_params[2]
    tau <- curr_params[3]
    cond_sd <- sqrt(1 / (tau * (1 + phi^2)))
    
    cens_idx <- which(delta == 0)
    interior_cens <- cens_idx[cens_idx > 1 & cens_idx < n]
    
    for (j in interior_cens) {
      cond_mean <- mu + (phi / (1 + phi^2)) * (y_curr[j-1] + y_curr[j+1] - 2 * mu)
      y_curr[j] <- rtruncnorm(1, a = z[j], b = Inf, mean = cond_mean, sd = cond_sd)
    }
  }
  
  cat("Parameter Acceptance Rate:", acc_count / n_iter, "\n")
  return(list(mcmc_res = mcmc(samples), final_y = y_curr))
}

results <- gibbs_censored_ar1(clouds, n_iter = 25000)

res_chain <- results$mcmc_res
final_y   <- results$final_y

summary(res_chain)
plot(res_chain)
autocorr.plot(res_chain)
plot(final_y, type = "l", col = "blue", lwd = 1,
     main = "Realisation of Cloud Heights",
     xlab = "Time (Hours)", ylab = "log(Cloud Ceiling Height)")
lines(clouds$z, col = "gray", lwd = 2)
legend("topright", legend = c("Imputed Latent y", "Observed/Censored Limit"), 
       col = c("blue", "gray"), lty = 1, lwd = c(1, 2), bty = "n")
@

