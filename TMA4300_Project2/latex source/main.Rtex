\subsection{Point f)}
In this point, we consider the limiting case of $\alpha \rightarrow 0$ as an attempt at being completely non-imformative. The priors for $\nu$ and $\tau$ then converge to improper objective so-called scale priors $\pi(\nu) \propto 1/\nu$ and $\pi(\tau) \propto 1/\tau$. We first make some changes in the previous code for Gibbs sampler so we will be able to change the initial values. We set $\alpha = 0$. Then we try different starting values, as shown in the code below. Because plotting $1/\nu$ directly can hide what is happening near zero, we rather create trace plots for $\log{(1/\nu)}$. 

<<problem2f, fig.width=5, fig.height=4, eval=FALSE, out.width='0.7\\textwidth'>>=
run_gibbs_f <- function(data, iterations = 20000, start_nu = 1, start_tau = 1) {
  y <- data$y
  group <- as.numeric(as.factor(data$i))
  m <- max(group)
  N <- length(y)
  ni <- as.numeric(table(group))
  alpha <- 0
  
  mu <- mean(y)
  gamma <- rep(0, m)
  tau <- start_tau
  nu <- start_nu
  
  samples <- matrix(NA, iterations, 3)
  colnames(samples) <- c("mu", "var_eps", "var_gamma")
  
  for (s in 1:iterations) {
    mu <- rnorm(1, sum(y - gamma[group]) / N, sqrt(1 / (N * tau)))
    
    prec_gamma <- ni * tau + nu
    mean_gamma <- (tau * tapply(y - mu, group, sum)) / prec_gamma
    gamma <- rnorm(m, mean_gamma, sqrt(1 / prec_gamma))
    
    ss_eps <- sum((y - mu - gamma[group])^2)
    tau <- rgamma(1, N/2, 0.5 * ss_eps)
    
    ss_gamma <- sum(gamma^2)
    nu <- rgamma(1, m/2, 0.5 * ss_gamma)
    
    samples[s, ] <- c(mu, 1/tau, 1/nu)
  }
  return(samples)
}

res_f1 <- run_gibbs_f(data, 20000, 1, 1)
res_f2 <- run_gibbs_f(data, 20000, 0.0001, 1)
res_f3 <- run_gibbs_f(data, 20000, 1000, 1)
res_f4 <- run_gibbs_f(data, 20000, 1, 0.0001)
res_f5 <- run_gibbs_f(data, 20000, 1, 1000)

par(mfrow = c(5, 2), mar = c(3, 3, 2, 1))

plot(res_f1[, 3], type = "l", main = "Plot 1 var")
plot(log(res_f1[, 3]), type = "l", main = "Plot 1 log-var")

plot(res_f2[, 3], type = "l", main = "Plot 2 var")
plot(log(res_f2[, 3]), type = "l", main = "Plot 2 log-var")

plot(res_f3[, 3], type = "l", main = "Plot 3 var")
plot(log(res_f3[, 3]), type = "l", main = "Plot 3 log-var")

